# Main Geppetto configuration
# Copy this to /etc/geppetto/main.conf and adjust paths as needed.

[defaults]
# Path to the default plan file (.fops or .toml)
plan = "/etc/geppetto/config/hosts/host1/plan.fops"

# Location for state data (used to clean up resources removed from the plan).
# If omitted, the state file defaults to <plan>.state.json.
state_file = "/var/lib/geppetto/state.json"

# Base directory for relative templates (optional). When set, template references
# like template => "templates/motd.tmpl" resolve under this directory.
template_dir = "/etc/geppetto/config/templates"

# Optional: log file location (defaults to /var/log/geppetto/geppetto.log).
log_file = "/var/log/geppetto/geppetto.log"

# Optional: Git-backed config repo. If set, geppetto-auto will clone/fetch+reset this
# path before running (including dry-run), discarding local edits to match origin.
# config_repo_path = "/etc/geppetto/config"
# config_repo_url  = "git@github.com:yourorg/geppetto-config.git"

# Optional: REST-backed config service. If set, geppetto-auto will download a
# host-specific config bundle into config_service_path before running. Leave
# plan unset to use /etc/geppetto/config/hosts/<hostname>/plan.fops automatically.
# config_service_url = "https://config.example.com"
# config_service_path = "/etc/geppetto/config"
# config_service_host = "host1"
# If these files are missing, geppetto-auto fetches the CA, creates a key/CSR,
# and submits the CSR to the server for signing.
# If omitted, these default to /etc/geppetto/pki/ca.crt and
# /etc/geppetto/pki/<hostname>.{crt,key}.
# config_service_ca_cert = "/etc/geppetto/pki/ca.crt"
# config_service_client_cert = "/etc/geppetto/pki/host1.crt"
# config_service_client_key = "/etc/geppetto/pki/host1.key"

# Optional: plugin modules/dirs to extend operations. Each module/file may define
# register_operations(registry) to add custom actions.
# plugin_modules = ["yourpackage.geppetto_plugins"]
# plugin_dirs = ["/etc/geppetto/plugins"]
# (See examples/plugins/custom_ops.py for a starter plugin.)
